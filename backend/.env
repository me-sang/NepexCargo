# App
NODE_ENV=development
PORT=3001

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nepex_cargo
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Storage
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./storage/uploads

# AWS S3 (if STORAGE_DRIVER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# UPS
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=
UPS_SANDBOX=true

# FedEx
FEDEX_API_KEY=
FEDEX_SECRET_KEY=
FEDEX_ACCOUNT_NUMBER=
FEDEX_SANDBOX=true

# DHL
DHL_API_KEY=
DHL_SANDBOX=true
