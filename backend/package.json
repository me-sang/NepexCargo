{
  "name": "nepex-cargo-backend",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "nodemon",
    "build": "tsc && cp .env dist/.env",
    "start": "node dist/server.js",
    "worker": "ts-node -r tsconfig-paths/register src/workers/worker.bootstrap.ts",
    "seed": "ts-node -r tsconfig-paths/register src/database/seeders/index.ts",
    "migration:run": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:revert",
    "migration:generate": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:generate",
    "migration:show": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:show",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --testPathPattern=tests/e2e",
    "test:coverage": "jest --coverage",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' 'app.ts' 'server.ts'",
    "format:write": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' 'app.ts' 'server.ts'",
    "lint:check": "eslint 'src/**/*.ts' 'tests/**/*.ts' 'app.ts' 'server.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' 'app.ts' 'server.ts' --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "axios": "^1.7.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "envalid": "^8.0.0",
    "express": "^4.19.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.12.0",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.0",
    "stripe": "^16.0.0",
    "typeorm": "^0.3.20",
    "winston": "^3.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.2",
    "@eslint/js": "^9.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "globals": "^15.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0"
  }
}
